# Production environment template
# Copy to .env and fill in real values before deploying

NODE_ENV=production
APP_NAME=fastify-enterprise-starter
APP_PORT=3000
APP_HOST=0.0.0.0
API_PREFIX=/api/v1
LOG_LEVEL=info

# Use managed PostgreSQL connection string with pooling
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public&connection_limit=10&pool_timeout=30

# Managed Redis
REDIS_HOST=your-redis-host
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
REDIS_KEY_PREFIX=app:

# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_64_CHAR_RANDOM_STRING
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=https://your-frontend.com
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_MS=900000

# SMTP (Resend, SendGrid, AWS SES, etc.)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASSWORD=re_your_api_key
SMTP_FROM=noreply@yourdomain.com

OTEL_ENABLED=false
OTEL_SERVICE_NAME=enterprise-fastify-backend
OTEL_EXPORTER_OTLP_ENDPOINT=https://your-otel-collector/v1/traces

# Use S3 in production
STORAGE_DRIVER=s3
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

S3_BUCKET=your-bucket
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_PUBLIC_URL=https://your-bucket.s3.amazonaws.com
S3_FORCE_PATH_STYLE=false

# Do not use default seed credentials in production
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=Use-A-Strong-Unique-Password-Here
