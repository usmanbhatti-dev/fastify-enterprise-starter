# Application
NODE_ENV=development
APP_NAME=fastify-enterprise-starter
APP_PORT=3000
APP_HOST=0.0.0.0
API_PREFIX=/api/v1
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/enterprise_db?schema=public&connection_limit=10&pool_timeout=30

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=app:

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Security
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW_MS=900000
BCRYPT_MEMORY_COST=65536
BCRYPT_TIME_COST=3
BCRYPT_PARALLELISM=4

# Email (SMTP — used by BullMQ email worker)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com

# OpenTelemetry
OTEL_ENABLED=false
OTEL_SERVICE_NAME=enterprise-fastify-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Storage (local | s3)
STORAGE_DRIVER=local
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# S3-compatible storage (when STORAGE_DRIVER=s3)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_URL=
S3_FORCE_PATH_STYLE=false

# Seed
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin@123456
